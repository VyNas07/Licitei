# ============================================================
# Licitei — Mobile (React Native + Expo)
# Copie este arquivo para .env e preencha com seus valores.
# NUNCA commite o arquivo .env.
# Variáveis com prefixo EXPO_PUBLIC_ ficam visíveis no bundle.
# ============================================================

# --- Supabase ---
# Encontre em: Project Settings → API
# Use a anon/public key aqui — nunca a service_role key
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon_key>

# --- Backend API ---
# URL base da API REST (Elysia)
EXPO_PUBLIC_API_URL=http://localhost:3000
