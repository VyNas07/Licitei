# ============================================================
# Licitei — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores.
# NUNCA commite o arquivo .env.
# ============================================================

# --- API PNCP ---
# URL base da API de consultas (não alterar)
PNCP_BASE_URL=https://pncp.gov.br/api/consulta/v1

# Registros por página — máximo permitido pela API é 50
PNCP_TAMANHO_PAGINA=50

# Filtro por estado (sigla UF, ex: PE, SP, RJ). Deixar vazio para todos os estados.
PNCP_UF=PE

# Código da modalidade de contratação (8 = Dispensa de Licitação)
PNCP_CODIGO_MODALIDADE=8

# Intervalo de datas da extração (formato: YYYYMMDD)
PNCP_DATA_INICIAL=20250101
PNCP_DATA_FINAL=20251231

# --- MongoDB Atlas ---
MONGO_URI=mongodb+srv://<usuario>:<senha>@cluster.mongodb.net/
MONGO_DB_NAME=licitei
MONGO_COLLECTION=contratacoes

# --- SQLite (diferencial) ---
# Caminho para o banco local. Deixar vazio para desabilitar a carga no SQLite.
SQLITE_DB_PATH=data/licitei.db
