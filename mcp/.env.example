# ============================================================
# Licitei — MCP (FastMCP + Python)
# Copie este arquivo para .env e preencha com seus valores.
# NUNCA commite o arquivo .env.
# ============================================================

# --- Servidor ---
MCP_HOST=0.0.0.0
MCP_PORT=8000

# --- MongoDB Atlas ---
# Mesma instância usada pelo ETL
MONGO_URI=mongodb+srv://<usuario>:<senha>@cluster.mongodb.net/
MONGO_DB_NAME=licitei
MONGO_COLLECTION=contratacoes

# --- Supabase ---
# Usado para ler perfil MEI (cnae, uf) ao processar contexto do usuário
# Encontre em: Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service_role_key>

# --- LLM ---
# Produção: OpenAI gpt-4o-mini
OPENAI_API_KEY=<openai_api_key>
LLM_MODEL=gpt-4o-mini

# Desenvolvimento: Ollama local (fallback quando OPENAI_API_KEY não está definido)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# --- Cache ---
# TTL em segundos para respostas em cache (padrão: 1 hora)
CACHE_TTL=3600
